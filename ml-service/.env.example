# =============================================================================
# ML Service Configuration
# =============================================================================
# Copy this file to .env and modify as needed

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
DEBUG=false
HOST=0.0.0.0
PORT=8001

# -----------------------------------------------------------------------------
# CORS (comma-separated origins)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Risk Classification Thresholds
# -----------------------------------------------------------------------------
# Probability thresholds for risk level classification
LOW_RISK_THRESHOLD=0.33
HIGH_RISK_THRESHOLD=0.66

# -----------------------------------------------------------------------------
# Eye Tracker Feature Engineering
# -----------------------------------------------------------------------------
# Sequence window size (number of fixations per sequence)
EYE_TRACKER_SEQUENCE_LENGTH=20
# Step size for sliding window
EYE_TRACKER_SEQUENCE_STEP=5
# Maximum number of sequences to generate
EYE_TRACKER_MAX_SEQUENCES=100
# Minimum fixation duration to include (milliseconds)
EYE_TRACKER_MIN_FIXATION_MS=80
# Maximum fixation duration to include (milliseconds)
EYE_TRACKER_MAX_FIXATION_MS=1000

# -----------------------------------------------------------------------------
# Webcam Feature Engineering (I-DT + One Euro)
# -----------------------------------------------------------------------------
# Minimum fixation duration to filter noise (milliseconds)
WEBCAM_MIN_FIXATION_MS=50
# Maximum fixation duration to include (milliseconds)
WEBCAM_MAX_FIXATION_MS=1500
# I-DT dispersion threshold (normalized units)
WEBCAM_IDT_DISPERSION_THRESHOLD=0.04
# I-DT minimum seed window duration (milliseconds)
WEBCAM_IDT_MIN_WINDOW_MS=150
# Fallback line transition threshold on normalized Y (when no line centers are provided)
WEBCAM_LINE_TRANSITION_THRESHOLD=0.04
# One Euro filter base cutoff
WEBCAM_ONE_EURO_MINCUTOFF=1.0
# One Euro filter speed coefficient
WEBCAM_ONE_EURO_BETA=0.007
# One Euro derivative cutoff
WEBCAM_ONE_EURO_DCUTOFF=1.0
# Target sequences for webcam model
WEBCAM_MAX_SEQUENCES=82
# Minimum sequences required for valid prediction
WEBCAM_MIN_SEQUENCES=10
