# =============================================================================
# ML Service Configuration
# =============================================================================
# Copy this file to .env and modify as needed

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
DEBUG=false
HOST=0.0.0.0
PORT=8001

# -----------------------------------------------------------------------------
# CORS (comma-separated origins)
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Risk Classification Thresholds
# -----------------------------------------------------------------------------
# Probability thresholds for risk level classification
LOW_RISK_THRESHOLD=0.33
HIGH_RISK_THRESHOLD=0.66

# -----------------------------------------------------------------------------
# Prediction QA Configurations
# -----------------------------------------------------------------------------
# Minimum sequences required for valid prediction. In development/testing,
# this can be set to 1 to allow short tests. In production, this must be 10.
WEBCAM_MIN_SEQUENCES=10
