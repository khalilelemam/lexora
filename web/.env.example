# ──────────────────────────────────────────────────────────────
# Lexora Web — Environment Variables
# Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Auth (Better Auth) ───────────────────────────────────────

# PostgreSQL connection string.
# For Neon (production): postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lexora?sslmode=require
# For Docker (local):    postgresql://lexora:lexora_dev@localhost:5433/lexora
DATABASE_URL=
# Optional local/CI shadow DB used by Prisma migration generation.
SHADOW_DATABASE_URL=

# Optional direct / non-pooled PostgreSQL connection string.
# Useful for Prisma migrations in CI/CD. For local Docker, it can match DATABASE_URL.
DATABASE_URL_UNPOOLED=

# Which Prisma adapter to use: "neon" (serverless WebSocket) or "pg" (standard TCP).
# Auto-detected from DATABASE_URL if omitted (URLs containing "neon.tech" → neon, otherwise → pg).
# Set explicitly when the auto-detection doesn't apply (e.g. Neon URL without "neon.tech").
# DATABASE_ADAPTER=

# Secret key for Better Auth (min 32 chars, high entropy).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of your app (used for OAuth callbacks, magic link URLs, etc.)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend API key for sending magic link emails
RESEND_API_KEY=

# Email sender address for magic links
EMAIL_FROM=Lexora <noreply@lexora.page>

# GitHub token used by the download proxy for private releases
LEXORA_RELEASES_TOKEN=

# ── Backend Services ──────────────────────────────────────────

# URL of the ML prediction service (Python FastAPI backend).
# Server-side only — NOT exposed to the browser.
# Default: http://localhost:8001
ML_SERVICE_URL=http://localhost:8001

# Azure Blob Storage connection string used to persist raw/derived JSON
# for test attempts.
#
# Local Docker/Azurite default:
#   UseDevelopmentStorage=true
#
# Production:
#   Replace with the real Azure Storage connection string.
AZURE_BLOB_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true

# Single Azure Blob container name used for both prefixes:
# - raw/{attemptId}.json
# - derived/{attemptId}.json
AZURE_BLOB_STORAGE_CONTAINER=test-attempts

# URL of the Tobii eye tracker helper service (desktop app).
# NEXT_PUBLIC_ prefix: this is used client-side to connect via WebSocket.
# Default: http://localhost:28980
NEXT_PUBLIC_TOBII_SERVICE_URL=http://localhost:28980

# ── Tobii Configuration ──────────────────────────────────────

# Timeout (ms) for the Tobii status check request.
# If the Tobii helper app doesn't respond within this time, it's
# considered offline. Keep this short for fast UX feedback.
# Default: 3000 (3 seconds)
NEXT_PUBLIC_TOBII_STATUS_TIMEOUT_MS=3000

# ── MediaPipe / Webcam Eye Tracking ──────────────────────────

# Version of the @mediapipe/tasks-vision package.
# Used to construct CDN URLs for the WASM bundle and JS module.
# Must match an available version on npm/jsdelivr.
# Default: 0.10.32
NEXT_PUBLIC_MEDIAPIPE_VERSION=0.10.32

# URL of the MediaPipe FaceLandmarker model file (.task).
# Change to a self-hosted copy for offline/airgapped or faster loading.
# Default: Google Cloud Storage hosted model
NEXT_PUBLIC_MEDIAPIPE_MODEL_URL=https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task

# Ideal webcam capture width (pixels). Higher = more accurate iris
# tracking but more CPU usage. Minimum recommended: 640.
# Default: 640
NEXT_PUBLIC_WEBCAM_WIDTH=640

# Ideal webcam capture height (pixels).
# Default: 480
NEXT_PUBLIC_WEBCAM_HEIGHT=480

# ── Debug / Development ──────────────────────────────────────

# Enable the real-time gaze dot overlay during the webcam reading task.
# Set to "true" to enable. Any other value = disabled.
# Default: false
NEXT_PUBLIC_DEBUG_GAZE_OVERLAY=false

# Enable verbose browser-console diagnostics for calibration fitting,
# pursuit sampling, and quick validation. Development builds enable these
# logs automatically; production builds require this env var.
# Default: false in production
NEXT_PUBLIC_DEBUG_CALIBRATION_LOG=false
