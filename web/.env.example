# ──────────────────────────────────────────────────────────────
# Lexora Web — Environment Variables
# Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── Auth (Better Auth) ───────────────────────────────────────

# PostgreSQL connection string.
# For Neon (production): postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lexora?sslmode=require
# For Docker (local):    postgresql://lexora:lexora_dev@localhost:5433/lexora
DATABASE_URL=

# Which Prisma adapter to use: "neon" (serverless WebSocket) or "pg" (standard TCP).
# Auto-detected from DATABASE_URL if omitted (URLs containing "neon.tech" → neon, otherwise → pg).
# Set explicitly when the auto-detection doesn't apply (e.g. Neon URL without "neon.tech").
# DATABASE_ADAPTER=

# Secret key for Better Auth (min 32 chars, high entropy).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of your app (used for OAuth callbacks, magic link URLs, etc.)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend API key for sending magic link emails
RESEND_API_KEY=

# Email sender address for magic links
EMAIL_FROM=Lexora <noreply@lexora.app>

# GitHub token used by the download proxy for private releases
LEXORA_RELEASES_TOKEN=

# ── Backend Services ──────────────────────────────────────────

# URL of the ML prediction service (Python FastAPI backend).
# Server-side only — NOT exposed to the browser.
# Default: http://localhost:8001
ML_SERVICE_URL=http://localhost:8001

# URL of the Tobii eye tracker helper service (desktop app).
# NEXT_PUBLIC_ prefix: this is used client-side to connect via WebSocket.
# Default: http://localhost:28980
NEXT_PUBLIC_TOBII_SERVICE_URL=http://localhost:28980

# ── Tobii Configuration ──────────────────────────────────────

# Timeout (ms) for the Tobii status check request.
# If the Tobii helper app doesn't respond within this time, it's
# considered offline. Keep this short for fast UX feedback.
# Default: 3000 (3 seconds)
NEXT_PUBLIC_TOBII_STATUS_TIMEOUT_MS=3000

# ── Calibration Tuning ───────────────────────────────────────

# Seconds of countdown before calibration collection starts.
# 5 seconds gives children adequate time to read instructions.
# Range: 3–10
# Default: 5
NEXT_PUBLIC_CALIBRATION_COUNTDOWN_SECONDS=5

# Minimum stable fixation duration (ms) before accepting a sample.
# Research consensus (Rayner 2009, Holmqvist 2017) recommends 250–350ms.
# Lower = more samples but noisier. Higher = fewer but cleaner samples.
# Range: 100–500
# Default: 300
NEXT_PUBLIC_STABLE_FIXATION_MS=300

# Maximum gaze velocity (fraction of screen diagonal per second) for
# fixation detection. Below this = fixation, above = saccade.
# 0.55 = movement < 55% of screen diagonal per second.
# Range: 0.2–1.0
# Default: 0.55
NEXT_PUBLIC_STABLE_VELOCITY_THRESHOLD=0.55

# Minimum cooldown (ms) between successive sample captures.
# Prevents over-sampling during a single fixation.
# Range: 20–200
# Default: 45
NEXT_PUBLIC_CAPTURE_COOLDOWN_MS=45

# Time (ms) to let gaze settle before measuring each validation point.
# Range: 200–1000
# Default: 450
NEXT_PUBLIC_VALIDATION_SETTLE_MS=450

# Duration (ms) to hold fixation during validation measurement.
# Range: 500–3000
# Default: 1200
NEXT_PUBLIC_VALIDATION_HOLD_MS=1200

# Validation accuracy threshold as fraction of screen diagonal.
# A distance <= this fraction scores 100%. Smaller = stricter.
# Range: 0.05–0.25
# Default: 0.12
NEXT_PUBLIC_VALIDATION_THRESHOLD=0.12

# ── Test Screen / Gaze Detection ─────────────────────────────

# Calibration quality thresholds (normalized error fraction).
# < good = excellent, good–acceptable = usable, > acceptable = poor.
# Default: 0.04 (good), 0.08 (acceptable)
NEXT_PUBLIC_CALIBRATION_THRESHOLD_GOOD=0.04
NEXT_PUBLIC_CALIBRATION_THRESHOLD_ACCEPTABLE=0.08

# Minimum gaze points required per reading task before submission.
# The ML service needs at least this many to extract features.
# Default: 20
NEXT_PUBLIC_MIN_GAZE_POINTS=20

# EMA smoothing factor for webcam gaze coordinates (0–1).
# Lower = heavier smoothing (less jitter but more lag).
# Higher = lighter smoothing (more responsive but noisier).
# Default: 0.3
NEXT_PUBLIC_WEBCAM_EMA_ALPHA=0.3

# ── MediaPipe / Webcam Eye Tracking ──────────────────────────

# Version of the @mediapipe/tasks-vision package.
# Used to construct CDN URLs for the WASM bundle and JS module.
# Must match an available version on npm/jsdelivr.
# Default: 0.10.32
NEXT_PUBLIC_MEDIAPIPE_VERSION=0.10.32

# URL of the MediaPipe FaceLandmarker model file (.task).
# Change to a self-hosted copy for offline/airgapped or faster loading.
# Default: Google Cloud Storage hosted model
NEXT_PUBLIC_MEDIAPIPE_MODEL_URL=https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task

# Ideal webcam capture width (pixels). Higher = more accurate iris
# tracking but more CPU usage. Minimum recommended: 640.
# Default: 640
NEXT_PUBLIC_WEBCAM_WIDTH=640

# Ideal webcam capture height (pixels).
# Default: 480
NEXT_PUBLIC_WEBCAM_HEIGHT=480

# ── Debug / Development ──────────────────────────────────────

# Enable the real-time gaze dot overlay on the reading screen.
# Also enables console diagnostic logs and auto-validation.
# Set to "true" to enable. Any other value = disabled.
# Default: false
NEXT_PUBLIC_DEBUG_GAZE_OVERLAY=false
