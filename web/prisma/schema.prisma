// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ───────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TestMode {
  TOBII
  WEBCAM
}

enum AttemptTaskType {
  FULL_BATTERY
  PARAGRAPH
  SYLLABLES
  PSEUDO_WORDS
  MEANINGFUL_TEXT
}

enum AttemptOutcome {
  LOW
  MEDIUM
  HIGH
}

enum CalibrationMode {
  GRID
  STAR
  STICKMAN
}

// ── Better Auth core models ─────────────────────────────

model User {
  id            String   @id
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ── Consent ───────────────────────────────
  termsAcceptedAt DateTime? // When the user last accepted the Terms and Privacy Policy
  rawDataConsent  Boolean   @default(true) // Opt-in for raw gaze data storage for research and model retraining

  sessions     Session[]
  accounts     Account[]
  testAttempts TestAttempt[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

model TestAttempt {
  attemptId        String          @id @db.Uuid
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testType         TestMode
  taskType         AttemptTaskType
  outcome          AttemptOutcome
  modelVersion     String
  calibrationMode  CalibrationMode
  age              Int
  label            String?
  // Snapshot of the user's consent state when this specific attempt was submitted.
  rawDataConsented Boolean         @default(false)
  rawBlobUrl       String?
  derivedBlobUrl   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([testType, createdAt])
  @@index([taskType, createdAt])
}
